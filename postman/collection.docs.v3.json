{
  "info": {
    "name": "Meridian \u2013 Identity \u2013 Docs",
    "description": "KYC/KYB identity verification and short-lived auth token issuance for the Meridian platform.\n\n## Purpose\n\nDocumentation collection \u2014 the consumer-facing surface.\n\n## Getting started\n\nObtain OAuth 2.0 client credentials from the Meridian developer portal, then exchange for an access token. See `Authentication` for full detail.\n\n## Consumers\n\n- External integrators\n- Solutions engineering\n\n## Conventions\n\n- Every folder maps 1:1 to a resource\n- Every request has rich markdown documentation",
    "schema": "https://schema.postman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "f40043bb-f0a9-4dd0-aab8-5a15621db759"
  },
  "auth": {
    "type": "oauth2",
    "oauth2": [
      {
        "key": "grant_type",
        "value": "client_credentials",
        "type": "string"
      },
      {
        "key": "accessTokenUrl",
        "value": "https://auth.meridianfs.example/oauth2/token",
        "type": "string"
      },
      {
        "key": "clientId",
        "value": "{{client_id}}",
        "type": "string"
      },
      {
        "key": "clientSecret",
        "value": "{{client_secret}}",
        "type": "string"
      },
      {
        "key": "scope",
        "value": "read write",
        "type": "string"
      },
      {
        "key": "tokenName",
        "value": "meridian-access-token",
        "type": "string"
      },
      {
        "key": "addTokenTo",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate fresh Idempotency-Key for mutating requests",
          "if (['POST','PUT','PATCH','DELETE'].indexOf(pm.request.method) !== -1) {",
          "  pm.request.headers.upsert({key:'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}')});",
          "}",
          "// Correlation ID for Repro Mode",
          "pm.request.headers.upsert({key:'X-Correlation-Id', value: pm.variables.replaceIn('cor_{{$guid}}')});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_url}}",
      "type": "string"
    }
  ],
